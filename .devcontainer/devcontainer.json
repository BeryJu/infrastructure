{
	"name": "Python 3",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers-extra/features/terraform-asdf:2": {},
		"ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {}
	},
	"postCreateCommand": "./.devcontainer/setup.sh",
	"mounts": [
		{
			"type": "bind",
			"source": "${localEnv:HOME}/.vault-token",
			"target": "/home/vscode/.vault-token"
		}
	],
	"containerEnv": {
		"VAULT_ADDR": "${localEnv:VAULT_ADDR}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.ansible",
				"redhat.vscode-yaml",
				"charliermarsh.ruff",
				"ms-python.python"
			],
			"settings": {
				"[yaml]": {
					"editor.tabSize": 2,
					"editor.defaultFormatter": "redhat.vscode-yaml"
				},
				"ansible.python.interpreterPath": "/workspaces/infrastructure/.venv/bin/python"
			}
		}
	}
}
